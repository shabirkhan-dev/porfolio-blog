# Supabase (read-only) - Project Settings -> API Keys
# This project only READS published posts from Supabase. Writing/automating
# posts will live in a separate dashboard project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key (safe to expose in the browser) - replaces the legacy anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy anon key (deprecated) - only used as a fallback if the publishable key
# above is not set.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: public site URL for sitemap/metadata
NEXT_PUBLIC_SITE_URL=https://shabirkhan.dev
